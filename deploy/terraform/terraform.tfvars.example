# Copy this file to terraform.tfvars and fill in your values.
# `terraform.tfvars` is gitignored.

# Use a non-default AWS profile (matches `aws configure --profile <name>`).
# Leave commented to fall back to environment vars / default credential chain.
aws_profile = "personal"

# Fail-safe: terraform aborts if active credentials map to a different account.
# Get yours with:  aws sts get-caller-identity --profile personal --query Account --output text
expected_account_id = "123456789012"

domain_name = "example.com"

# Contents of your public key. e.g. `cat ~/.ssh/id_ed25519.pub`
ssh_pubkey = "ssh-ed25519 AAAA... your-comment"

# Strongly recommended: restrict SSH to your own IP only.
#   curl ifconfig.me   then append /32
allowed_ssh_cidr = "0.0.0.0/0"

# Set to false if a Route53 hosted zone for domain_name already exists.
create_hosted_zone = true

# Defaults (uncomment to override):
# region            = "ap-northeast-2"
# project_name      = "web-server"
# ec2_instance_type = "t3.micro"
