# Copy to group_vars/all.yml (gitignored) and fill in your values.

# ---- Domain ----
domain_name: hyeontae.cloud
include_www: true

# ---- Let's Encrypt ----
letsencrypt_email: you@example.com
# Use the staging endpoint while you iterate to avoid hitting prod rate limits.
# Flip to false once everything works.
letsencrypt_staging: true

# ---- App container / ECR ----
aws_region: ap-northeast-2
ecr_account_id: "123456789012"
ecr_repository: web-server
app_image_tag: latest
# Computed: <account>.dkr.ecr.<region>.amazonaws.com/<repo>:<tag>
app_image: "{{ ecr_account_id }}.dkr.ecr.{{ aws_region }}.amazonaws.com/{{ ecr_repository }}:{{ app_image_tag }}"
app_container_name: web_server
app_host_port: 8080
app_container_port: 8080

# ---- Firewall ----
ufw_allowed_tcp:
  - 22
  - 80
  - 443
